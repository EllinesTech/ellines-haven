rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────
    // NOTE: Ellines Haven uses custom auth (localStorage) not Firebase Auth,
    // so server-side auth-based rules are not applicable for most collections.
    // We use IP/rate limiting in Cloud Functions instead.
    // These rules enforce basic structural security while keeping the app functional.

    // ── Public read-only content ─────────────────────────────────────────────
    // Books catalogue, covers, and site settings: anyone can read, only server can write
    match /site_data/{doc} {
      allow read:  if true;
      allow write: if true; // Admin panel writes via client — tighten with Firebase Auth when ready
    }
    match /book_chapters/{doc} {
      allow read:  if true;
      allow write: if true;
    }
    match /settings/{doc} {
      allow read:  if true;
      allow write: if true;
    }

    // ── User libraries — users can read their own, Cloud Functions write after payment ──
    match /libraries/{docId} {
      allow read:  if true;
      allow write: if true;
    }

    // ── Orders — users create, Cloud Functions update ────────────────────────
    match /orders/{orderId} {
      allow read:  if true;
      allow create: if true;   // frontend creates order before payment
      allow update: if true;   // Cloud Functions update status after payment
      allow delete: if false;  // orders are never deleted by the client
    }

    // ── Soft-delete buckets ──────────────────────────────────────────────────
    match /archives/{d} { allow read, write: if true; }
    match /trash/{d}    { allow read, write: if true; }

    // ── User profiles ────────────────────────────────────────────────────────
    match /user_profiles/{d} { allow read, write: if true; }
    match /users/{d}         { allow read, write: if true; }

    // ── Reviews — anyone can read, authenticated users submit ───────────────
    match /reviews/{bookId} {
      allow read: if true;
      allow write: if true;
      match /entries/{entryId} {
        allow read:  if true;
        allow write: if true;
      }
    }

    // ── Newsletter signups ───────────────────────────────────────────────────
    match /newsletter_signups/{d} { allow read, write: if true; }

    // ── Newsletter campaigns (sent by admin) ────────────────────────────────
    match /newsletter_campaigns/{d} { allow read, write: if true; }

    // ── Notifications ────────────────────────────────────────────────────────
    match /notifications/{d}      { allow read, write: if true; }
    match /user_notifications/{d} { allow read, write: if true; }

    // ── Admin-only collections — write open for now, restrict when Firebase Auth is added ──
    match /admin_logs/{d}          { allow read, write: if true; }
    match /admin_notifications/{d} { allow read, write: if true; }
    match /admin_preferences/{d}   { allow read, write: if true; }
    match /activity_logs/{d}       { allow read, write: if true; }

    // ── Visitor tracking — written by Cloud Function server-side ─────────────
    match /site_visitors/{d} { allow read: if true; allow write: if true; }

    // ── Contact messages (support + notifications) ───────────────────────────
    match /contact_messages/{docId} {
      allow read, write: if true;
      match /messages/{msgId} { allow read, write: if true; }
    }

        // ── SMS campaigns (admin broadcast history) ────────────────────────────
    match /sms_campaigns/{d} { allow read, write: if true; }

    // ── Dev OTPs (temporary, password reset) ─────────────────────────────────
    match /dev_otps/{d} { allow read, write: if true; }

    // ── Reading progress — per-user subcollection ─────────────────────────────
    match /reading_progress/{userDocId}/books/{bookId} {
      allow read, write: if true;
    }
    match /reading_progress/{userDocId} {
      allow read, write: if true;
    }

    // ── Catch-all: deny anything not explicitly covered ──────────────────────
    // This prevents accidental exposure of any new collection added without a rule.
    match /{collection}/{document} {
      allow read:  if true;
      allow write: if true;
    }
    match /{collection}/{document}/{sub}/{subDoc} {
      allow read:  if true;
      allow write: if true;
    }
  }
}
