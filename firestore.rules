rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── NOTE ──────────────────────────────────────────────────────────────
    // This app uses custom localStorage-based auth, NOT Firebase Auth.
    // Therefore request.auth is always null and all collections that the
    // app needs must be open (allow read, write: if true).
    // Sensitive admin-only writes are protected at the application layer.
    // ─────────────────────────────────────────────────────────────────────

    match /site_data/{doc} {
      allow read, write: if true;
    }

    match /reviews/{doc} {
      allow read, write: if true;
    }

    match /books/{doc} {
      allow read, write: if true;
    }

    match /user_profiles/{email} {
      allow read, write: if true;
    }

    match /libraries/{docId} {
      allow read, write: if true;
    }

    // Notify Me requests — users write, admin reads
    match /notifications/{docId} {
      allow read, write: if true;
    }

    match /admin_notifications/{docId} {
      allow read, write: if true;
    }

    match /orders/{docId} {
      allow read, write: if true;
    }

    // contact_messages and ALL subcollections (threads live here)
    match /contact_messages/{docId} {
      allow read, write: if true;
    }
    match /contact_messages/{docId}/messages/{msgId} {
      allow read, write: if true;
    }

    match /admin_logs/{docId} {
      allow read, write: if true;
    }

    // Catch-all: deny anything not explicitly listed
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
