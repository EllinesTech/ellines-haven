rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{d}                                        { allow read, write: if true; }
    match /archives/{d}                                      { allow read, write: if true; }
    match /libraries/{d}                                     { allow read, write: if true; }
    match /site_data/{d}                                     { allow read, write: if true; }
    match /book_chapters/{d}                                 { allow read, write: if true; }
    match /settings/{d}                                      { allow read, write: if true; }
    match /user_profiles/{d}                                 { allow read, write: if true; }
    match /users/{d}                                         { allow read, write: if true; }
    match /reviews/{d}                                       { allow read, write: if true; }
    match /notifications/{d}                                 { allow read, write: if true; }
    match /user_notifications/{d}                            { allow read, write: if true; }
    match /admin_logs/{d}                                    { allow read, write: if true; }
    match /admin_notifications/{d}                           { allow read, write: if true; }
    match /contact_messages/{docId}                          { allow read, write: if true; }
    match /contact_messages/{docId}/messages/{msgId}         { allow read, write: if true; }
    match /{document=**}                                     { allow read, write: if false; }
  }
}
