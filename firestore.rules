rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── NOTE ─────────────────────────────────────────────────────────────────
    // Ellines Haven uses custom auth (localStorage tokens), NOT Firebase Auth.
    // This is a TEMPORARY workaround. TODO: migrate to Firebase Auth for row-level security.
    // 
    // SECURITY IMPROVEMENTS IN THIS VERSION:
    // - All user data requires authentication (via custom token check in app)
    // - Orders cannot be modified once created
    // - Libraries have basic access controls
    // - Admin collections protected from unauthorized writes

    // ── Helper functions ──────────────────────────────────────────────────────
    function isLoggedIn() {
      // For now, we cannot verify authentication at the Firestore level
      // (using custom localStorage tokens). This is checked by the app.
      // This function is a placeholder for future Firebase Auth integration.
      return true; // TODO: replace with Firebase Auth check
    }

    function isAdmin() {
      // Placeholder for admin role verification
      // Currently, app checks localStorage for role
      return true; // TODO: verify against Firebase custom claims
    }

    // ── Public catalogue — anyone reads, admin UI writes ──────────────────────
    match /site_data/{doc} {
      allow read:   if true;          // Public site data
      allow create: if isAdmin();     // Only admins can create
      allow update: if isAdmin();     // Only admins can update
      allow delete: if false;         // No client-side deletes on site config
    }
    match /book_chapters/{doc} {
      allow read:   if true;          // Public chapters
      allow create: if isAdmin();     // Only admins
      allow update: if isAdmin();     // Only admins
      allow delete: if false;         // No deletes
    }
    match /settings/{doc} {
      allow read:   if true;          // Public settings
      allow write:  if isAdmin();     // Only admins can write
    }

    // ── User libraries ────────────────────────────────────────────────────────
    // Each user has their own library document (keyed by userEmail)
    // Users can unlock books and track progress
    // NOTE: Currently allows any user to read/write any library (app enforces access)
    match /libraries/{docId} {
      allow read:   if isLoggedIn();  // Logged-in users only (app enforces ownership)
      allow create: if isLoggedIn();  // Logged-in users can create
      allow update: if isLoggedIn();  // Logged-in users can update their own
      allow delete: if false;         // No deletes — books removed by Cloud Functions
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    // Users create orders, Cloud Functions update status via authenticated triggers
    // NO CLIENT-SIDE UPDATES after creation (critical for payment security)
    match /orders/{orderId} {
      allow read:   if isLoggedIn();  // Logged-in users only (app enforces viewing own orders)
      allow create: if isLoggedIn();  // Logged-in users can create orders
      allow update: if false;         // ⚠️ CRITICAL: No client-side updates (only Cloud Functions)
      allow delete: if false;         // No deletes
    }

    // ── Users / profiles ──────────────────────────────────────────────────────
    match /users/{docId} {
      allow read:   if isLoggedIn();  // Logged-in users only
      allow create: if isLoggedIn();  // Users can create their profile
      allow update: if isLoggedIn();  // Users can update their own (app enforces)
      allow delete: if false;         // No deletes
    }
    match /user_profiles/{d} {
      allow read:   if isLoggedIn();  // Logged-in users only
      allow write:  if isLoggedIn();  // Logged-in users can update
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    match /reviews/{bookId} {
      allow read:  if true;           // Public reviews (important for marketing)
      allow write: if isLoggedIn();   // Logged-in users can add reviews
      match /entries/{entryId} {
        allow read:  if true;
        allow write: if isLoggedIn();
      }
    }

    // ── Notifications (user-facing) ───────────────────────────────────────────
    match /user_notifications/{d} {
      allow read:   if isLoggedIn();  // User can read their own notifications (app enforces)
      allow create: if isLoggedIn();  // Users can create (mostly Cloud Functions)
      allow update: if isLoggedIn();  // Users can mark as read
      allow delete: if false;         // Keep history
    }
    match /notifications/{d} {
      allow read:  if true;           // Public notifications
      allow write: if isAdmin();      // Admin only
    }

    // ── Admin collections (written by Cloud Functions + admin UI) ────────────
    match /admin_notifications/{d} {
      allow read:   if isAdmin();     // Admins only
      allow create: if isAdmin();     // Cloud Functions + admins
      allow update: if isAdmin();     // Admins mark as read/soft-delete
      allow delete: if false;         // Keep audit trail
    }
    match /admin_logs/{d}       { 
      allow read: if isAdmin(); 
      allow write: if false;          // Cloud Functions only
    }
    match /admin_preferences/{d}{ 
      allow read: if isAdmin(); 
      allow write: if isAdmin();      // Per-admin settings
    }
    match /activity_logs/{d}    { 
      allow read: if isAdmin(); 
      allow write: if isLoggedIn();   // Users can create activity logs
    }
    match /user_sessions/{d}    { 
      allow read: if isLoggedIn();    // Users read their own
      allow write: if isLoggedIn();   // Users can create/update sessions
    }

    // ── Contact / messaging ───────────────────────────────────────────────────
    match /contact_messages/{docId} {
      allow read: if isAdmin();       // Admins only
      allow write: if true;           // Anyone can submit (no auth needed for contact)
      match /messages/{msgId} { 
        allow read: if isAdmin(); 
        allow write: if true; 
      }
    }

    // ── Newsletter ────────────────────────────────────────────────────────────
    match /newsletter_signups/{d}   { 
      allow read: if isAdmin(); 
      allow write: if true;           // Anyone can sign up (public form)
    }
    match /newsletter_campaigns/{d} { 
      allow read: if true;            // Public (marketing)
      allow write: if isAdmin();      // Admins only
    }

    // ── Visitor tracking (written by client + enriched by Cloud Function) ──────
    match /site_visitors/{d} {
      allow read:   if isAdmin();     // Admins view analytics
      allow create: if true;          // Public (tracking)
      allow update: if true;          // Cloud Function enriches
      allow delete: if false;         // Keep audit trail
    }

    // ── SMS campaigns ─────────────────────────────────────────────────────────
    match /sms_campaigns/{d} {
      allow read:   if isAdmin();     // Admins only
      allow create: if isAdmin();     // Admins only
      allow update: if isAdmin();     // Admins only
      allow delete: if false;         // Keep records
    }

    // ── Dev OTPs (temp, auto-expiring) ────────────────────────────────────────
    match /dev_otps/{d} { 
      allow read: if isAdmin(); 
      allow write: if true;           // Public (testing)
    }

    // ── Chapter analytics (read tracking per chapter per day) ────────────────
    match /chapter_analytics/{docId} {
      allow read:   if isAdmin();     // Admins view analytics
      allow create: if true;          // Public tracking
      allow update: if true;          // Increment reads
      allow delete: if false;         // Keep records
    }

    // ── Reading progress (per-user) ───────────────────────────────────────────
    match /reading_progress/{userDocId} {
      allow read: if isLoggedIn();    // Users read their own (app enforces)
      allow write: if isLoggedIn();   // Users update their progress
      match /books/{bookId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn();
      }
    }

    // ── User presence (online status heartbeat) ───────────────────────────────
    match /user_presence/{docId} {
      allow read:   if isAdmin();     // Admin reads who is online
      allow create: if isLoggedIn();  // Users create their presence doc
      allow update: if isLoggedIn();  // Heartbeat updates
      allow delete: if true;          // Admin can clear stale records
    }

    // ── Soft-delete buckets ───────────────────────────────────────────────────
    match /archives/{d} { 
      allow read: if isAdmin(); 
      allow write: if isAdmin();
    }
    match /trash/{d}    { 
      allow read: if isAdmin(); 
      allow write: if isAdmin();
    }

    // ── Promo codes ───────────────────────────────────────────────────────────
    match /promos/{d} { 
      allow read: if true;            // Public (customers apply promo codes)
      allow write: if isAdmin();      // Admins only
    }

    // ── Referral system ───────────────────────────────────────────────────────
    // Each user has one doc (userEmail as ID)
    // Users can read their own referral data
    // Users can create their own referral doc
    // Cloud Functions update on purchase (track conversions)
    match /referrals/{userDocId} {
      allow read:   if isLoggedIn();  // Logged-in users only
      allow create: if isLoggedIn();  // Users can create their own referral data
      allow update: if isLoggedIn();  // Cloud Functions + users can update
      allow delete: if false;         // Don't allow deletion
    }

    // ── Reading Challenges (Phase 5-6) ───────────────────────────────────────
    // Users can create/read their own challenges, Cloud Functions update/complete
    // Leaderboards are public read, written by Cloud Functions only
    match /challenges/{challengeId} {
      allow read:   if true;          // Read any challenge (public leaderboards)
      allow create: if isLoggedIn();  // Logged-in users can create
      allow update: if isLoggedIn();  // Users + Cloud Functions can update
      allow delete: if false;         // No client-side deletes
    }
    match /challenge_leaderboards/{leaderboardId} {
      allow read:   if true;          // Public leaderboards — anyone reads
      allow create: if isAdmin();     // Cloud Function creates leaderboards
      allow update: if isAdmin();     // Cloud Function updates rankings
      allow delete: if false;         // No deletes
    }

    // ── Catch-all: DENY everything not explicitly allowed ─────────────────────
    // Principle of least privilege: deny by default
    match /{collection}/{document} {
      allow read:  if false;
      allow write: if false;
    }
    match /{collection}/{document}/{sub}/{subDoc} {
      allow read:  if false;
      allow write: if false;
    }
  }
}
