rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── NOTE ─────────────────────────────────────────────────────────────────
    // Ellines Haven uses custom auth (localStorage tokens), NOT Firebase Auth.
    // Full server-side auth rules require migrating to Firebase Auth.
    // Current approach: open reads, controlled writes — prevents the worst
    // abuse (bulk deletes, arbitrary library unlocks) without breaking the app.
    // TODO: migrate to Firebase Auth for row-level security.

    // ── Public catalogue — anyone reads, client writes (admin panel) ──────────
    match /site_data/{doc} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;   // no client-side deletes on site config
    }
    match /book_chapters/{doc} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }
    match /settings/{doc} {
      allow read:   if true;
      allow write:  if true;
    }

    // ── User libraries ────────────────────────────────────────────────────────
    // Allow read + create + update (for unlock and progress).
    // Deny delete — books can only be removed by Cloud Functions / admin.
    match /libraries/{docId} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    // Users create orders, Cloud Functions update status.
    // No client-side deletes.
    match /orders/{orderId} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ── Users / profiles ──────────────────────────────────────────────────────
    match /users/{docId} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }
    match /user_profiles/{d} {
      allow read:   if true;
      allow write:  if true;
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    match /reviews/{bookId} {
      allow read:  if true;
      allow write: if true;
      match /entries/{entryId} {
        allow read:  if true;
        allow write: if true;
      }
    }

    // ── Notifications (user-facing) ───────────────────────────────────────────
    match /user_notifications/{d} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;   // mark as read
      allow delete: if false;
    }
    match /notifications/{d} {
      allow read:  if true;
      allow write: if true;
    }

    // ── Admin collections (written by Cloud Functions + admin UI) ────────────
    match /admin_notifications/{d} {
      allow read:   if true;
      allow create: if true;   // Cloud Functions write new notifications
      allow update: if true;   // Admin UI marks as read / soft-deletes
      allow delete: if false;
    }
    match /admin_logs/{d}       { allow read: if true; allow write: if false; }
    match /admin_preferences/{d}{ allow read, write: if true; }  // Per-admin settings
    match /activity_logs/{d}    { allow read: if true; allow write: if true; }
    match /user_sessions/{d}    { allow read: if true; allow write: if true; }

    // ── Contact / messaging ───────────────────────────────────────────────────
    match /contact_messages/{docId} {
      allow read, write: if true;
      match /messages/{msgId} { allow read, write: if true; }
    }

    // ── Newsletter ────────────────────────────────────────────────────────────
    match /newsletter_signups/{d}   { allow read, write: if true; }
    match /newsletter_campaigns/{d} { allow read, write: if true; }

    // ── Visitor tracking (written by Cloud Function) ──────────────────────────
    match /site_visitors/{d} {
      allow read:   if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    // ── SMS campaigns ─────────────────────────────────────────────────────────
    match /sms_campaigns/{d} {
      allow read:   if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    // ── Dev OTPs (temp, auto-expiring) ────────────────────────────────────────
    match /dev_otps/{d} { allow read, write: if true; }

    // ── Reading progress (per-user) ───────────────────────────────────────────
    match /reading_progress/{userDocId} {
      allow read, write: if true;
      match /books/{bookId} {
        allow read, write: if true;
      }
    }

    // ── User presence (online status heartbeat) ───────────────────────────────
    match /user_presence/{docId} {
      allow read:   if true;   // Admin reads who is online
      allow create: if true;   // Users create their presence doc on login
      allow update: if true;   // Heartbeat updates + admin force-logout flag
      allow delete: if true;   // Admin can clear stale records
    }

    // ── Soft-delete buckets ───────────────────────────────────────────────────
    match /archives/{d} { allow read, write: if true; }
    match /trash/{d}    { allow read, write: if true; }

    // ── Promo codes ───────────────────────────────────────────────────────────
    match /promos/{d} { allow read, write: if true; }

    // ── Referral system ───────────────────────────────────────────────────────
    // Each user has one doc (userEmail as ID)
    // Users can read their own referral data
    // Users can create their own referral doc
    // Cloud Functions update on purchase (track conversions)
    match /referrals/{userDocId} {
      allow read:   if true;  // Anyone can read (needed to validate codes)
      allow create: if true;  // Users can create their own referral data
      allow update: if true;  // Cloud Functions update on conversions
      allow delete: if false; // Don't allow deletion
    }

    // ── Catch-all: READ yes, WRITE no for anything not explicitly covered ─────
    // This prevents accidental write exposure on new collections.
    match /{collection}/{document} {
      allow read:  if true;
      allow write: if false;
    }
    match /{collection}/{document}/{sub}/{subDoc} {
      allow read:  if true;
      allow write: if false;
    }
  }
}
